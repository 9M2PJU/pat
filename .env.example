# Pat Environment Configuration Example
# Copy this file to .env and customize for your station.

# --- Identity & Location ---
# Your amateur radio callsign (required)
PAT_MYCALL=W1AW

# Maidenhead grid square (e.g. FN31pr)
PAT_LOCATOR=FN31pr

# Winlink password (for secure login challenges)
PAT_SECURE_LOGIN_PASSWORD=your_secure_password

# --- Web Interface ---
# The address and port for the web UI
PAT_HTTP_ADDR=:8080

# --- General Settings ---
# Comma-separated list of methods to listen on (e.g. ardop,telnet,ax25)
PAT_LISTEN=telnet,ardop

# Max message size for automatic download (bytes). -1 for no limit.
PAT_AUTO_DOWNLOAD_SIZE_LIMIT=-1

# --- ARDOP Configuration ---
PAT_ARDOP_ADDR=localhost:8515
PAT_ARDOP_ARQ_BANDWIDTH=500MAX
PAT_ARDOP_RIG=my_rig
PAT_ARDOP_PTT_CTRL=true

# --- VARA HF Configuration ---
PAT_VARAHF_ADDR=localhost:8300
PAT_VARAHF_BANDWIDTH=2300
PAT_VARAHF_RIG=my_rig
PAT_VARAHF_PTT_CTRL=true

# --- Telnet Configuration ---
PAT_TELNET_LISTEN_ADDR=:8774
PAT_TELNET_PASSWORD=secret

# --- Hamlib Rig Configuration (Custom Syntax) ---
# Format: PAT_HAMLIB_RIGS_{name}_{ATTRIBUTE}
# PAT_HAMLIB_RIGS_my_rig_ADDRESS=localhost:4532
# PAT_HAMLIB_RIGS_my_rig_NETWORK=tcp
# PAT_HAMLIB_RIGS_my_rig_VFO=A
